# ---- Ashigaru-Search config (copy to .env) ----

# Worker fleet (Ashigaru scouts) — the model that runs search sub-tasks. Point at your vLLM server.
ASHIGARU_WORKER_BASE_URL=http://localhost:8000/v1
ASHIGARU_WORKER_MODEL=lfm25-8b-a1b
ASHIGARU_WORKER_API_KEY=EMPTY

# Orchestrator (Commander) — plans & synthesizes. Leave blank to reuse the worker model,
# or point at a bigger model (e.g. a 27B NVFP4 on another port).
ASHIGARU_ORCH_BASE_URL=
ASHIGARU_ORCH_MODEL=
ASHIGARU_ORCH_API_KEY=

# Search backends
SEARXNG_URL=http://localhost:8888
# ASHIGARU_RAG_INDEX=/path/to/index.pkl     # set to enable local BM25 doc_search/read_chunk
# ASHIGARU_EMAKI=/path/to/scroll            # built KURA-Emaki scroll dir -> tree+graph navigation
#                                             (build offline: ashigaru-emaki <corpus> <out> --no-llm)

# Behaviour
ASHIGARU_MAX_CONCURRENCY=16
ASHIGARU_MAX_SUBQUESTIONS=6
ASHIGARU_FLEET_SIZE=10          # S/M/L density tags = 10% / 50% / 100% of this (ceil, min 1)
ASHIGARU_WORKER_MAX_STEPS=6
# quality gate: escalate density (S->M->L, numeric ×2) and redo if reports are thin
ASHIGARU_ESCALATE=1
ASHIGARU_MAX_ESCALATIONS=2
ASHIGARU_QUALITY_MIN_CHARS=160
ASHIGARU_QUALITY_JUDGE=1
# mid-search check-ins: Commander orders continue/regroup/return after each lead
ASHIGARU_SUPERVISE=1
ASHIGARU_SUPERVISE_AFTER=1      # start checking in after this many tool steps
ASHIGARU_MAX_CHECKINS=5         # max Commander consultations per scout (lower = cheaper)
ASHIGARU_SEARCH_RESULTS=6
ASHIGARU_FETCH_CHAR_LIMIT=6000
ASHIGARU_TEMPERATURE=0.2
ASHIGARU_VERBOSE=1

# Commander token budget — reasoning models burn tokens on <think> before content; the
# default 3072 can yield an empty synthesis with many rich scout reports. 16384 is safe.
ASHIGARU_ORCH_MAX_TOKENS=16384

# Per-role Commander reasoning ("auto"|"on"|"off"; reasoning-model commanders only). Measured:
# thinking OFF for grounded synthesis/judgment is ~4-5x faster with equal-or-better accuracy and
# stays honest; planning benefits from thinking. (See docs/FLEET-RECIPE.md §6.)
ASHIGARU_ORCH_THINK_PLAN=auto
ASHIGARU_ORCH_THINK_SYNTH=auto
ASHIGARU_ORCH_THINK_JUDGE=auto
# Player-coach: send the idle Commander out as one extra premium scout (opt-in; no measured
# accuracy gain in the sweep, adds wall-time).
ASHIGARU_COMMANDER_SCOUT=0

# ---- egress sovereignty: default-deny outbound gate + audit (SSRF defence) ----
ASHIGARU_EGRESS_GATE=1                 # 0 disables the gate entirely (legacy behaviour)
ASHIGARU_EGRESS_FETCH_OPEN=1           # honour search-discovered hosts as the fetch capability
# ASHIGARU_EGRESS_ALLOW=my.searx,internal.docs   # extra hostnames always permitted
# ASHIGARU_EGRESS_AUDIT=./egress-audit.jsonl      # append-only log of every host contacted
